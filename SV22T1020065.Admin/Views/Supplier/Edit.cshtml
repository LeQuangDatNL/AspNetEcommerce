@model Supplier
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-building me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Supplier/SaveData">

                    <input type="hidden" asp-for="SupplierID" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tên nhà cung cấp</label>
                            <input type="text" asp-for="SupplierName" class="form-control" placeholder="Nhập tên nhà cung cấp" />
                            <span asp-validation-for="SupplierName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Tên giao dịch</label>
                            <input type="text" asp-for="ContactName" class="form-control" placeholder="Nhập tên giao dịch" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel" asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" asp-for="Email" class="form-control" placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control" asp-for="Address" rows="3" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" asp-for="Province" asp-items="await SelectListHelper.Provinces()"></select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>