@model PagedResult<Supplier>
@{
    ViewBag.Title = "Quản lý Nhà cung cấp";
}

@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="@Url.Action("Search", "Supplier")"
              data-target="searchResult"
              onsubmit="return paginationSearch(event, this, 1);">

            <input type="hidden" name="PageSize" value="@Model.PageSize" />

            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       placeholder="Tên nhà cung cấp..."
                       value="@ViewBag.SearchValue" autofocus />

                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), 1);
        });
    </script>
}