@model PagedResult<Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
                method ="get"
                action="@Url.Action("Search", "Product")"
                data-target="searchResult"
                onsubmit="return paginationSearch(event, this, 1);">
            <div class="row g-2">


                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <!-- 🔹 Category -->
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" name="CategoryID" asp-items="await SelectListHelper.Categories()"></select>

                </div>

                <!-- 🔹 Supplier -->
                <div class="col-md-3">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="SupplierID" asp-items="await SelectListHelper.Suppliers()"></select>
                </div>

                <!-- 🔹 Price -->
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="number"
                               name="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="number"
                               name="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <!-- 🔹 Search -->
                <div class="col-md-3">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               name="SearchValue"
                               value="@ViewBag.SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), 1);
        });
    </script>
}