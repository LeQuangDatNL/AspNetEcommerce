@model ProductAttribute
@{
    var productId = ViewBag.ProductId ?? 0;
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="@Url.Action("Edit", "Product", new { id = productId })#attribute" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thêm mới thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post" asp-action="CreateAttribute" asp-controller="Product" asp-route-id="@productId">
                    <input type="hidden" name="ProductID" value="@productId" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input name="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị thuộc tính <span class="text-danger">*</span>
                        </label>
                        <div class="col-sm-9">
                            <input name="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input name="DisplayOrder"
                                   class="form-control"
                                   type="number"
                                   value="1"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
