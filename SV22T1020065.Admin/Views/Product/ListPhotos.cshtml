@model List<SV22T1020065.Models.Catalog.ProductPhoto>
@{
    Layout = null;
    var productId = ViewBag.ProductId ?? 0;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="@Url.Action("CreatePhoto", "Product", new { id = productId })">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="@(string.IsNullOrEmpty(item.Photo)
                                                        ? Url.Content("~/images/products/nophoto.png")
                                                        : Url.Content($"~/images/products/{item.Photo}"))"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center">
                                        <span class="badge @(item.IsHidden ? "bg-secondary" : "bg-success")">
                                            @(item.IsHidden ? "Ẩn" : "Hiện")
                                        </span>
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="@Url.Action("EditPhoto", "Product", new { id = productId, photoId = item.PhotoID })">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="@Url.Action("DeletePhoto", "Product", new { id = productId, photoId = item.PhotoID })" onclick="return confirm('Bạn có muốn xóa ảnh này không?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Chưa có ảnh nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>