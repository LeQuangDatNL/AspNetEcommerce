@model SV22T1020065.Models.Catalog.ProductPhoto
@{
    var productId = ViewBag.ProductId ?? 0;
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu ảnh
    </button>

    <a href="@Url.Action("Edit", "Product", new { id = productId })#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">Thông tin ảnh mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data" asp-action="EditPhoto" asp-controller="Product" asp-route-id="@productId" asp-route-photoId="@Model.PhotoID">
                    <input asp-for="PhotoID" type="hidden" />
                    <input type="hidden" name="ProductID" value="@productId" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="Photo"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview"
                                 src="@(string.IsNullOrEmpty(Model.Photo)
                                            ? Url.Content("~/images/products/nophoto.png")
                                            : Url.Content($"~/images/products/{Model.Photo}"))"
                                 class="img-thumbnail"
                                 style="max-height:200px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input asp-for="Description"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input asp-for="DisplayOrder"
                                   class="form-control"
                                   min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input asp-for="IsHidden"
                                       class="form-check-input"
                                       type="checkbox"
                                       id="IsHidden" />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh
                                </label>
                            </div>
                        </div>
                    </div>                    
                </form>
            </div>
        </div>
    </div>
</div>
