@model ProductPhoto
@{
    var productId = ViewBag.ProductId ?? 0;
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu ảnh
    </button>

    <a href="@Url.Action("Edit", "Product", new { id = productId })#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">Thêm mới ảnh mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post" enctype="multipart/form-data" asp-action="CreatePhoto" asp-controller="Product" asp-route-id="@productId">
                    <input type="hidden" name="ProductID" value="@productId" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Ảnh <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview"
                                 src="@Url.Content("~/images/products/nophoto.png")"
                                 class="img-thumbnail"
                                 style="max-height:200px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input name="Description"
                                   class="form-control"
                                   placeholder="Nhập mô tả ảnh" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input name="DisplayOrder"
                                   class="form-control"
                                   type="number"
                                   value="1"
                                   min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input name="IsHidden"
                                       class="form-check-input"
                                       type="checkbox"
                                       id="IsHidden"
                                       value="true" />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh
                                </label>
                            </div>
                        </div>
                    </div>                    
                </form>
            </div>
        </div>
    </div>
</div>
