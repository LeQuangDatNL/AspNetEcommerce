@model ProductAttribute
@{
    var productId = ViewBag.ProductId ?? 0;
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="@Url.Action("Edit", "Product", new { id = productId })#attribute" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="EditAttribute" asp-controller="Product" asp-route-id="@productId" asp-route-attributeId="@Model.AttributeID">
                    <input asp-for="AttributeID" type="hidden" />
                    <input asp-for="ProductID" type="hidden" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input asp-for="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input asp-for="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input asp-for="DisplayOrder"
                                   class="form-control"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
