@model SV22T1020065.Models.Catalog.Product

@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    @if (ViewBag.CannotDelete != true)
    {
        <button type="submit" form="formDelete" class="btn btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa mặt hàng này không?');">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    else
    {
        <button type="button" class="btn btn-danger" disabled>
            <i class="bi bi-trash me-1"></i>
            Không được xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa mặt hàng
                </h5>
            </div>

            <div class="card-body">
                @if (ViewBag.CannotDelete == true)
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        @ViewBag.ErrorMessage
                    </div>
                }
                <form id="formDelete" method="post">
                    <input asp-for="ProductID" type="hidden" />
                    @if (ViewBag.CannotDelete != true)
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa mặt hàng sau không?
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Tên mặt hàng</dt>
                                <dd class="col-sm-8">@Model.ProductName</dd>

                                <dt class="col-sm-4">Loại hàng</dt>
                                <dd class="col-sm-8">@ViewBag.CategoryName</dd>

                                <dt class="col-sm-4">Nhà cung cấp</dt>
                                <dd class="col-sm-8">@ViewBag.SupplierName</dd>

                                <dt class="col-sm-4">Đơn vị tính</dt>
                                <dd class="col-sm-8">@Model.Unit</dd>

                                <dt class="col-sm-4">Giá bán</dt>
                                <dd class="col-sm-8">@Model.Price.ToString("N0") đ</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    <span class="badge @(Model.IsSelling ? "bg-success" : "bg-secondary")">@(Model.IsSelling ? "Đang bán" : "Ngừng bán")</span>
                                </dd>

                                <dt class="col-sm-4">Mô tả</dt>
                                <dd class="col-sm-8">
                                    @Model.ProductDescription
                                </dd>
                            </dl>
                        </div>

                        <div class="col-md-4 text-end">
                            <img src="@(string.IsNullOrEmpty(Model.Photo)
                                        ? Url.Content("~/images/products/nophoto.png")
                                        : Url.Content($"~/images/products/{Model.Photo}"))"
                                 class="img-fluid img-thumbnail"
                                 alt="Ảnh mặt hàng"
                                 style="max-height: 220px;" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
