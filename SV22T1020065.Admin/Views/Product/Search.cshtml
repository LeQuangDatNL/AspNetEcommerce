@model PagedResult<Product>
@{
    Layout = null; 
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@(string.IsNullOrEmpty(item.Photo)
                                    ? Url.Content("~/images/products/demo.png")
                                    : Url.Content($"~/images/products/{item.Photo}"))"
                             class="img-thumbnail"
                             alt="@item.ProductName" />
                    </td>
                    <td>
                        <strong>@item.ProductName</strong><br />
                        @if (!string.IsNullOrEmpty(item.ProductDescription))
                                {
                                    <small class="text-muted">@item.ProductDescription</small>
                                }
                            </td>
                            <td>@item.Unit</td>
                            <td class="text-end">@item.Price.ToString("N0")</td>
                            <td class="text-center">
                                @if (item.IsSelling)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            Không tìm thấy mặt hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @* hiển thị phân trang giống PagedResult *@
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">«</a>
                </li>
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                        </li>
                    }
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">»</a>
                </li>
            </ul>
        </div>
    }
</div>