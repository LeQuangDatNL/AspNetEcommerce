@model List<OrderDetailViewInfo>
@using SV22T1020065.Models.Sales
@{
    ViewBag.Layout = null;
    int stt = 0; // biến thứ tự
    var orderStatus = (OrderStatusEnum?)ViewBag.OrderStatus ?? OrderStatusEnum.New;
    var canEditCart = orderStatus == OrderStatusEnum.New;
}

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive" style="max-height: 320px; overflow-y: auto;">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@(++stt)</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td> 
                            <td class="text-center">@item.Quantity</td> 
                            <td class="text-end">@item.SalePrice.ToString("N0")</td> 
                            <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-end">
                                @if (canEditCart)
                                {
                                    <a asp-action="EditCartItem"
                                       asp-controller="Order"
                                       asp-route-id="@item.OrderID"
                                       asp-route-productId="@item.ProductID"
                                       class="btn btn-sm btn-primary open-modal">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="DeleteCartItem"
                                       asp-controller="Order"
                                       asp-route-id="@item.OrderID"
                                       asp-route-productId="@item.ProductID"
                                       class="btn btn-sm btn-danger open-modal">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">Không có sản phẩm nào</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">
                        @Model?.Sum(x => x.SalePrice * x.Quantity).ToString("N0")
                    </th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
        
        @if (Model != null && Model.Any() && canEditCart)
        {
            <div class="mt-3 text-end">
                <a asp-action="ClearCart"
                   asp-controller="Order"
                   class="btn btn-danger open-modal">
                    <i class="bi bi-trash me-1"></i>
                    Xóa giỏ hàng
                </a>
            </div>
        }
    </div>
</div>