<!--Yes-->
@model OrderDetailsViewModel
@{
    ViewBag.Title = $"Chi tiết đơn hàng #{Model.Order.OrderID}";

    var badgeClass = Model.Order.Status switch
    {
        OrderStatusEnum.New => "alert-warning text-dark",
        OrderStatusEnum.Accepted => "alert-info text-dark",
        OrderStatusEnum.Shipping => "alert-primary text-white",
        OrderStatusEnum.Completed => "alert-success text-white",
        OrderStatusEnum.Cancelled => "alert-danger text-white",
        OrderStatusEnum.Rejected => "alert-danger text-white",
        _ => "alert-secondary text-dark"
    };
}

@section PageToolBar {
    @if (Model.Order.Status == OrderStatusEnum.New || Model.Order.Status == OrderStatusEnum.Accepted || Model.Order.Status == OrderStatusEnum.Shipping)
    {
        <div class="btn-group">
            <button type="button"
                    class="btn btn-primary dropdown-toggle"
                    data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i>
                Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @if (Model.Order.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item" href="@Url.Content("~/Order/Accept/" + Model.Order.OrderID)">Duyệt đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger" href="@Url.Content("~/Order/Reject/" + Model.Order.OrderID)">Từ chối đơn hàng</a></li>
                    <li><a class="dropdown-item text-danger" href="@Url.Content("~/Order/Cancel/" + Model.Order.OrderID)">Hủy đơn hàng</a></li>
                }
                @if (Model.Order.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item" href="@Url.Content("~/Order/Shipping/" + Model.Order.OrderID)">Chuyển giao hàng</a></li>
                    <li><a class="dropdown-item text-danger" href="@Url.Content("~/Order/Cancel/" + Model.Order.OrderID)">Hủy đơn hàng</a></li>
                }
                @if (Model.Order.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item" href="@Url.Content("~/Order/Finish/" + Model.Order.OrderID)">Hoàn tất đơn hàng</a></li>
                }
            </ul>
        </div>
    }

    @if (Model.Order.Status == OrderStatusEnum.Completed || Model.Order.Status == OrderStatusEnum.Cancelled || Model.Order.Status == OrderStatusEnum.Rejected)
    {
        <a href="@Url.Content("~/Order/Delete/" + Model.Order.OrderID)"
           class="btn btn-danger ms-1">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="alert @badgeClass d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Order.Status.GetDescription()
        @if (Model.Order.FinishedTime.HasValue)
        {
            <span>lúc <b>@Model.Order.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</b></span>
        }
    </div>
</div>

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.Order.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.Order.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@Model.Order.EmployeeName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.Order.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Ngày giao</div>
            <div class="col-md-3">@(Model.Order.ShippedTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>

            <div class="col-md-3 fw-bold">Ngày kết thúc</div>
            <div class="col-md-3">@(Model.Order.FinishedTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
        </div>
    </div>
</div>

<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.Order.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.Order.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.Order.CustomerEmail</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.Order.CustomerAddress</div>
        </div>
    </div>
</div>

<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.Order.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.Order.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.Order.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.Order.DeliveryProvince</div>
        </div>
    </div>
</div>

@await Html.PartialAsync("ShowCart", Model.Details)

