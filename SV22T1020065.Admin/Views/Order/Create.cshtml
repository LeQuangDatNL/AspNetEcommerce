@* @model PagedResult<Product>
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form method="get" action="~/Order/Create" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="searchValue"
                               value="@(ViewBag.SearchValue ?? "")"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng -->
                @if (Model?.DataItems != null && Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <form method="post" action="~/Order/AddToCart" class="border rounded p-2 mb-2">
                            <input type="hidden" name="productId" value="@item.ProductID" />
                            <strong>@item.ProductName</strong>

                            <div class="row mt-2">
                                <div class="col-4">
                                    <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/no-image.png") : Url.Content($"~/images/products/{item.Photo}"))"
                                         class="img-fluid border" style="max-height:100px" />
                                </div>
                                <div class="col-8">
                                    <div class="row g-2">
                                        <div class="col-7">
                                            <label class="form-label mb-0">Giá</label>
                                            <input class="form-control form-control-sm" readonly value="@item.Price.ToString("N0")" />
                                        </div>
                                        <div class="col-5">
                                            <label class="form-label mb-0">SL</label>
                                            <input type="number"
                                                   name="quantity"
                                                   min="1"
                                                   value="1"
                                                   class="form-control form-control-sm" />
                                        </div>
                                    </div>

                                    <button class="btn btn-sm btn-primary mt-2 w-100" type="submit">
                                        <i class="bi bi-cart-plus"></i>
                                        Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        Không tìm thấy sản phẩm.
                    </div>
                }
            </div>

            <div class="card-footer">
                <ul class="pagination justify-content-between mb-0">
                    <li class="page-item">
                        <a class="page-link" href="javascript:;">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="javascript:;">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12">
                <div class="card card-outline card-success">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-cart"></i>
                            Danh sách mặt hàng đã chọn
                        </h5>
                    </div>

                    <div class="card-body">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-success">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th style="width:auto">Tên hàng</th>
                                    <th class="text-center" style="width:100px">ĐVT</th>
                                    <th class="text-center" style="width:100px">SL</th>
                                    <th class="text-end" style="width:150px">Giá</th>
                                    <th class="text-end" style="width:150px">Thành tiền</th>
                                    <th style="width:80px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var car = Session["cart"] as List<CartItem>;
                                    int index = 0;
                                    decimal totalAmount = 0;
                                }
                                @if (cart.Count > 0)
                                {
                                    foreach (var item in cart)
                                    {
                                        totalAmount += item.Quantity * item.SalePrice;
                                        <tr>
                                            <td class="text-center">@(++index)</td>
                                            <td>@item.ProductName</td>
                                            <td class="text-center">@item.Unit</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                            <td class="text-end">@(item.Quantity * item.SalePrice).ToString("N0")</td>
                                            <td class="text-end text-nowrap">
                                                <a class="btn btn-sm btn-danger" href="~/Order/DeleteCartItem/0?productId=@item.ProductID">
                                                    <i class="bi bi-dash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">Giỏ hàng đang trống.</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="5" class="text-end">Tổng cộng:</th>
                                    <th class="text-end">
                                        @totalAmount.ToString("N0")
                                    </th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="text-end">
                            <a class="btn btn-sm btn-danger mt-2" href="~/Order/ClearCart">
                                <i class="bi bi-trash"></i>
                                Xóa giỏ hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select">
                                        <option>-- Chọn khách hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select">
                                        <option>-- Chọn Tỉnh/thành giao hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> *@
