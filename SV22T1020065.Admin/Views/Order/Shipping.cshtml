@model SV22T1020065.Models.Sales.OrderViewInfo
@using SV22T1020065.Models.Partner
@{
    ViewBag.Title = "Chuyển giao đơn hàng";
    var orderId = ViewBag.OrderId as int? ?? 0;
    var shippers = ViewBag.Shippers as List<Shipper> ?? new List<Shipper>();
}

@section PageToolBar {
    <button type="submit" form="formShipping" class="btn btn-primary">
        <i class="bi bi-bicycle me-1"></i>
        Chuyển giao
    </button>
    <a href="@Url.Action("Detail", "Order", new { id = orderId })" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person me-2"></i>Chọn người giao hàng</h5>
            </div>
            <div class="card-body">
                <form id="formShipping" method="post" asp-action="Shipping" asp-controller="Order" asp-route-id="@orderId">
                    <div class="mb-3">
                        <label class="form-label">Người giao hàng <span class="text-danger">*</span></label>
                        <select name="shipperId" class="form-select">
                            <option value="0">-- Chọn người giao hàng --</option>
                            @foreach (var shipper in shippers)
                            {
                                <option value="@shipper.ShipperID">@shipper.ShipperName - @shipper.Phone</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>

        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Thông tin đơn hàng</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div><strong>Mã đơn hàng:</strong> @Model.OrderID</div>
                        <div><strong>Khách hàng:</strong> @Model.CustomerName</div>
                    </div>
                    <div class="col-md-6">
                        <div><strong>Ngày lập:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
                        <div><strong>Trạng thái:</strong> @Model.Status.GetDescription()</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
