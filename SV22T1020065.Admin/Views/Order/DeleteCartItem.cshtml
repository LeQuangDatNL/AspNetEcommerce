@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Xóa mặt hàng khỏi đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="alert alert-danger d-flex align-items-center">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có muốn xóa mặt hàng này ra khỏi đơn hàng không?
    </div>
</div>

<div class="modal-footer">
    <form id="formDeleteCartItem" method="post" asp-action="DeleteCartItem" asp-controller="Order" asp-route-id="@ViewBag.OrderId">
        <input type="hidden" name="productId" value="@ViewBag.ProductId" />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </form>
</div>