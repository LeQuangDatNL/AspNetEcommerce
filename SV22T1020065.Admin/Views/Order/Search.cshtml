@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.CustomerName</td>
                            <td>@item.CustomerPhone</td>
                            <td>@(item.AcceptTime?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@item.EmployeeName</td>
                            <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center">
                                @switch (item.Status)
                                {
                                    case OrderStatusEnum.New:
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>;
                                        break;
                                    case OrderStatusEnum.Accepted:
                                        <span class="badge bg-info text-dark">Đã duyệt</span>;
                                        break;
                                    case OrderStatusEnum.Shipping:
                                        <span class="badge bg-primary">Đang giao</span>;
                                        break;
                                    case OrderStatusEnum.Completed:
                                        <span class="badge bg-success">Hoàn tất</span>;
                                        break;
                                    case OrderStatusEnum.Cancelled:
                                        <span class="badge bg-danger">Bị hủy</span>;
                                        break;
                                    case OrderStatusEnum.Rejected:
                                        <span class="badge bg-danger">Bị từ chối</span>;
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@item.Status</span>;
                                        break;
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="@Url.Content("~/Order/Detail/" + item.OrderID)" class="btn btn-sm btn-primary">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Không tìm thấy đơn hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                        «
                    </a>
                </li>

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                        »
                    </a>
                </li>
            </ul>
        </div>
    }
</div>
