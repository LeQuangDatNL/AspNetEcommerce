@model SV22T1020065.Models.Common.PagedResult<SV22T1020065.Models.Catalog.Product>
@using SV22T1020065.Models.Sales
@{
    ViewBag.Title = "Tìm kiếm sản phẩm";
}

<div class="card card-outline card-primary">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-search me-2"></i>Tìm kiếm sản phẩm</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="SearchProduct" asp-controller="Order" class="mb-4">
            <div class="input-group">
                <input type="text" name="searchValue" value="@(ViewBag.SearchValue ?? "")" class="form-control" placeholder="Nhập từ khóa" />
                <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </form>

        @if (Model?.DataItems != null && Model.DataItems.Any())
        {
            foreach (var item in Model.DataItems)
            {
                <div class="card card-sm rounded-3 mb-3 p-3">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-3">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/nophoto.png") : Url.Content($"~/images/products/{item.Photo}"))"
                                 class="img-fluid rounded border" style="max-height:100px;" />
                        </div>
                        <div class="col-md-6">
                            <h6>@item.ProductName</h6>
                            <div class="text-muted">@item.Unit</div>
                            <div class="fw-semibold text-primary">@item.Price.ToString("N0")</div>
                        </div>
                        <div class="col-md-3 text-end">
                            <form method="post" asp-action="AddToCart" asp-controller="Order">
                                <input type="hidden" name="productId" value="@item.ProductID" />
                                <div class="input-group mb-2">
                                    <input type="number" name="quantity" min="1" value="1" class="form-control form-control-sm" />
                                    <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-cart-plus"></i></button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-5">Không tìm thấy sản phẩm.</div>
        }
    </div>
</div>
