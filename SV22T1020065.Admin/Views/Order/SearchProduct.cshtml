@model SV22T1020065.Models.Common.PagedResult<SV22T1020065.Models.Catalog.Product>
@using SV22T1020065.Models.Sales
@{
    Layout = null;
}

<div style="padding-right: 0.5rem;">
    @if (Model.DataItems.Any())
    {
        foreach (var item in Model.DataItems)
        {
            <form method="post" asp-action="AddToCart" asp-controller="Order" class="card rounded-3 mb-2 shadow-sm">
                <input type="hidden" name="productId" value="@item.ProductID" />
                <div class="row g-0 align-items-center">
                    <div class="col-auto">
                        <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/nophoto.png") : Url.Content($"~/images/products/{item.Photo}"))"
                             class="img-fluid rounded-start border-end" style="width:100px; height:100px; object-fit:cover;" />
                    </div>
                    <div class="col">
                        <div class="card-body py-2 px-3">
                            <div class="fw-semibold mb-1" style="font-size: 0.95rem;">@item.ProductName</div>
                            <div class="text-muted small mb-1">@item.Unit</div>
                            <div class="text-primary fw-bold mb-2" style="font-size: 1.1rem;">@item.Price.ToString("N0") ₫</div>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="number" name="quantity" value="1" min="1" class="form-control form-control-sm" style="width:80px;" />
                                <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-cart-plus"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        }
    }
    else
    {
        <div class="text-center text-muted py-5">Không tìm thấy sản phẩm.</div>
    }
</div>

@if (Model.PageCount > 1)
{
    <div class="mb-2 text-center text-muted" style="font-size: 0.9rem;">
        Trang <strong>@Model.Page</strong> / <strong>@Model.PageCount</strong>
    </div>
    <div class="d-flex justify-content-center gap-2">
        <button class="btn btn-outline-primary btn-sm @(Model.HasPreviousPage ? "" : "disabled")"
                onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))"
                @(Model.HasPreviousPage ? "" : "disabled")>
            <i class="bi bi-chevron-left"></i> Trước
        </button>
        <button class="btn btn-outline-primary btn-sm @(Model.HasNextPage ? "" : "disabled")"
                onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))"
                @(Model.HasNextPage ? "" : "disabled")>
            Sau <i class="bi bi-chevron-right"></i>
        </button>
    </div>
}
