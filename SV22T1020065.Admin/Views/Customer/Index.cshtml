@model PagedResult<Customer>
@{
    ViewBag.Title = "Quản lý khách hàng";
}
@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="@Url.Action("Search", "Customer")"
              data-target="searchResult"
              onsubmit="return paginationSearch(event, this, 1);">

            <input type="hidden" name="PageSize" value="@Model.PageSize" />

            <div class="input-group">
                <input type="text" name="SearchValue"
                       value="@ViewBag.SearchValue"
                       class="form-control"
                       placeholder="Tên khách hàng, địa chỉ..." autofocus />

                <button type="submit" class="btn btn-info">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), 1);
        });
    </script>
}