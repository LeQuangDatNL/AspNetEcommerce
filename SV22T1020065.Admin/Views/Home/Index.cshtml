@{
    var userData = ViewBag.UserData as SV22T1020065.Admin.WebUserData;
}

@* TODO: Hiển thị thông tin người dùng hiện tại từ cookie và tách role ra riêng biệt. *@

<div class="row mb-3">
    <div class="col-12">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-circle me-1"></i> Người dùng hiện tại</h5>
            </div>
            <div class="card-body">
                @if (userData != null)
                {
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Tên hiển thị:</strong> @userData.DisplayName</p>
                            <p class="mb-1"><strong>Tên đăng nhập:</strong> @userData.UserName</p>
                            <p class="mb-1"><strong>Email:</strong> @userData.Email</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Vai trò:</strong> @(userData.Roles != null && userData.Roles.Any() ? string.Join(", ", userData.Roles) : "Chưa gán")</p>
                            <p class="mb-1"><strong>Mã người dùng:</strong> @userData.UserId</p>
                            <p class="mb-0 text-muted">Dữ liệu này được lấy từ cookie xác thực hiện tại.</p>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-warning mb-0">Không tìm thấy thông tin người dùng. Vui lòng đăng nhập lại.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">12.500.000 đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">48</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">320</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">128</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="150"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        Laptop Dell
                        <span class="badge bg-success">120</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        iPhone 15
                        <span class="badge bg-success">98</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        Tai nghe Sony
                        <span class="badge bg-success">76</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        Chuột Logitech
                        <span class="badge bg-success">65</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>#DH00125</td>
                            <td>Nguyễn Văn A</td>
                            <td>01/02/2026</td>
                            <td class="text-end">3.500.000 đ</td>
                            <td><span class="badge bg-danger">Đang chờ duyệt</span></td>
                        </tr>
                        <tr>
                            <td>#DH00126</td>
                            <td>Trần Thị B</td>
                            <td>01/02/2026</td>
                            <td class="text-end">1.200.000 đ</td>
                            <td><span class="badge bg-warning">Chờ giao hàng</span></td>
                        </tr>
                        <tr>
                            <td>#DH00127</td>
                            <td>Lê Văn C</td>
                            <td>31/01/2026</td>
                            <td class="text-end">8.900.000 đ</td>
                            <td><span class="badge bg-warning">Chờ giao hàng</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');

        new Chart(ctx, {
            type: 'bar', // bar | line | pie | doughnut
            data: {
                labels: [
                    'Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6'
                ],
                datasets: [{
                    label: 'Doanh thu (triệu đồng)',
                    data: [120, 150, 180, 140, 200, 220],
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return context.raw + ' triệu đồng';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}