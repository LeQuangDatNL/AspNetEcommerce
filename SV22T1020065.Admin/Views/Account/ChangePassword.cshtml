@{
    ViewBag.Title = "Thay đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-12">
        <form asp-action="ChangePassword" method="post">
            <div class="card card-warning card-outline">
                <div class="card-body">
                    <!-- Mật khẩu cũ -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu cũ</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input name="OldPassword" value="@ViewBag.OldPassword"
                                type="password" class="form-control" placeholder="Nhập mật khẩu cũ" autofocus>
                        </div>
                    </div>

                    <!-- Mật khẩu mới -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-shield-lock-fill"></i>
                            </span>
                            <input name="NewPassword" value="@ViewBag.NewPassword"
                                type="password" class="form-control" placeholder="Nhập mật khẩu mới">
                        </div>
                    </div>

                    <!-- Xác nhận mật khẩu mới -->
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-check-circle-fill"></i>
                            </span>
                            <input name="ConfirmPassword" value="@ViewBag.ConfirmPassword"
                                type="password" class="form-control" placeholder="Nhập lại mật khẩu mới">
                        </div>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Đổi mật khẩu
                    </button>
                    <a href="~/" class="btn btn-secondary me-2">
                        <i class="bi bi-back"></i> Quay lại
                    </a>
                </div>
            </div>
        </form>
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success mt-3">@ViewBag.Success</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">@ViewBag.Error</div>
        }

    </div>
</div>
