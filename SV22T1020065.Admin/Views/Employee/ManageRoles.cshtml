@model SV22T1020065.Models.HR.Employee
@{
    ViewBag.Title = "Quản lý quyền nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formManageRoles" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Cập nhật quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Quản lý quyền nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formManageRoles" method="post">

                      <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield me-1"></i>
                            Quyền của nhân viên
                        </legend>

                        <div class="mb-3">
                            <label class="form-label">Chọn quyền</label>
                            <select name="SelectedRoles" class="form-select" multiple>
                                <option value="employee" selected="@((ViewBag.SelectedRoles as List<string>)?.Contains("employee") ?? false)">Nhân viên</option>
                                <option value="admin" selected="@((ViewBag.SelectedRoles as List<string>)?.Contains("admin") ?? false)">Quản trị</option>
                                <option value="datamanager" selected="@((ViewBag.SelectedRoles as List<string>)?.Contains("datamanager") ?? false)">Quản lý dữ liệu</option>
                                <option value="sales" selected="@((ViewBag.SelectedRoles as List<string>)?.Contains("sales") ?? false)">Quản lý bán hàng</option>
                            </select>
                            <small class="form-text text-muted">Chọn các quyền cho nhân viên (có thể chọn nhiều)</small>
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>