@model PagedResult<Employee>
@{
    ViewBag.Title = "Quản lý Nhân viên";
}

@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Employee">
            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       placeholder="Nhập tên hoặc email nhân viên..."
                       value="@Context.Request.Query["searchValue"]" autofocus />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px">Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" style="width:140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/employees/user.png") : Url.Content($"~/images/employees/{item.Photo}"))"
                                 style="width:50px; height:50px; object-fit:cover" class="rounded-circle" />
                        </td>
                        <td>@item.FullName</td>
                        @* FIX LỖI: ToString cho DateTime? *@
                        <td>@item.BirthDate</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td class="text-center">
                            @* FIX LỖI: Ép kiểu bool? về bool *@
                            @if (item.IsWorking == true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã nghỉ việc</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger ms-1">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="?page=@(Model.Page - 1)&searchValue=@Context.Request.Query["searchValue"]">«</a>
                </li>

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="?page=@p.Page&searchValue=@Context.Request.Query["searchValue"]">@p.Page</a>
                        </li>
                    }
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="?page=@(Model.Page + 1)&searchValue=@Context.Request.Query["searchValue"]">»</a>
                </li>
            </ul>
        </div>
    }
</div>