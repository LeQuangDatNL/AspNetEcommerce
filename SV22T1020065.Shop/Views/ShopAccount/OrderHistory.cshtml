@model PagedResult<OrderViewInfo>
@using SV22T1020065.Models.Sales

@{
    ViewBag.Title = "Lịch sử mua hàng";
}

<div class="container mt-4" style="max-width:1200px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-clock-history me-2"></i> Lịch sử mua hàng
            </h5>
        </div>
        <div class="card-body">
            @if (!Model.DataItems.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn chưa có đơn hàng nào. <a href="~/ShopProduct/Index" class="alert-link">Bắt đầu mua sắm ngay</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày lập</th>
                                <th>Trạng thái</th>
                                <th>Nơi giao</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.DataItems)
                            {
                                <tr>
                                    <td class="fw-bold">#@order.OrderID</td>
                                    <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (order.Status == OrderStatusEnum.New)
                                        {
                                            <span class="badge bg-secondary">Chờ duyệt</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Accepted)
                                        {
                                            <span class="badge bg-info">Đã duyệt</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Shipping)
                                        {
                                            <span class="badge bg-warning">Đang giao</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Completed)
                                        {
                                            <span class="badge bg-success">Hoàn thành</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Cancelled)
                                        {
                                            <span class="badge bg-danger">Đã hủy</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Rejected)
                                        {
                                            <span class="badge bg-danger">Bị từ chối</span>
                                        }
                                    </td>
                                    <td>
                                        <small>@order.DeliveryProvince</small><br />
                                        <small class="text-muted">@order.DeliveryAddress</small>
                                    </td>
                                    <td>
                                        <a href="~/ShopOrder/Details/@order.OrderID" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Phân trang -->
           
            }
        </div>
        <div class="card-footer text-center">
            <a href="~/ShopProduct/Index" class="btn btn-primary">
                <i class="bi bi-shop me-2"></i> Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>
