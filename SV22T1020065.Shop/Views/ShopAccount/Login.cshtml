@{
    ViewBag.Title = "Đăng nhập";
}

<div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
    <div class="card shadow-lg rounded-4 p-4" style="width:100%; max-width:420px;">
        <div class="text-center mb-4">
            <h3 class="fw-bold">Đăng nhập</h3>
            <p class="text-muted mb-0">Sử dụng email và mật khẩu để truy cập cửa hàng</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small">@ViewBag.Error</div>
        }

        <form method="post" action="~/ShopAccount/Login">
            <div class="mb-3">
                <label class="form-label small text-secondary">Email</label>
                <input type="email" name="UserName" class="form-control form-control-lg" placeholder="Email" value="@ViewBag.UserName" required />
                <span class="text-danger small">@Html.ValidationMessage("UserName")</span>
            </div>

            <div class="mb-3">
                <label class="form-label small text-secondary">Mật khẩu</label>
                <input type="password" name="Password" id="loginPass" class="form-control form-control-lg" placeholder="Mật khẩu" required />
                <span class="text-danger small">@Html.ValidationMessage("Password")</span>
            </div>

            <div class="d-grid mb-3">
                <button class="btn btn-primary btn-lg">Đăng nhập</button>
            </div>

            <div class="text-center small text-muted">
                Chưa có tài khoản? <a href="~/ShopAccount/Register">Đăng ký ngay</a>
            </div>
        </form>
    </div>
</div>