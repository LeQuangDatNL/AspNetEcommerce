@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="container mt-4" style="max-width:500px;">
    <div class="card shadow-sm p-3">
        <h5 class="text-center text-primary mb-3">Đổi mật khẩu</h5>

        <!-- Thông báo lỗi -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger p-2 small">@ViewBag.Error</div>
        }

        <!-- Thông báo thành công -->
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success p-2 small">@ViewBag.Success</div>
        }

        <form method="post" action="~/ShopAccount/ChangePassword">

            <!-- Mật khẩu cũ -->
            <div class="mb-2">
                <label class="form-label small">Mật khẩu cũ</label>
                <input type="password" name="OldPassword" class="form-control form-control-sm"
                       value="@ViewBag.OldPassword" />
            </div>

            <!-- Mật khẩu mới -->
            <div class="mb-2">
                <label class="form-label small">Mật khẩu mới</label>
                <input type="password" name="NewPassword" class="form-control form-control-sm"
                       value="@ViewBag.NewPassword" />
            </div>

            <!-- Xác nhận mật khẩu -->
            <div class="mb-3">
                <label class="form-label small">Xác nhận mật khẩu</label>
                <input type="password" name="ConfirmPassword" class="form-control form-control-sm"
                       value="@ViewBag.ConfirmPassword" />
            </div>

            <div class="d-grid">
                <button class="btn btn-primary btn-sm">Đổi mật khẩu</button>
            </div>
        </form>
    </div>
</div>