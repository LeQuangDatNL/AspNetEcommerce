@model SV22T1020065.Models.Catalog.ProductDetailViewModel
@{
    Layout = null;
}

<div class="modal-header">
    <h5 class="modal-title">@Model.Product.ProductName</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <div class="row">
        <div class="col-md-4">
            @if (Model.Photos.Any())
            {
                <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.Photos.Count; i++)
                        {
                            var photo = Model.Photos[i];
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Url.Content($"~/images/products/{photo.Photo}")"
                                     class="d-block w-100 rounded"
                                     alt="@photo.Description"
                                     style="object-fit: cover; height: 300px;" />
                            </div>
                        }
                    </div>
                    @if (Model.Photos.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    }
                </div>

                @if (Model.Photos.Count > 1)
                {
                    <div class="row g-2 mt-2">
                        @foreach (var photo in Model.Photos.Take(4))
                        {
                            <div class="col-3">
                                <img src="@Url.Content($"~/images/products/{photo.Photo}")"
                                     class="img-thumbnail"
                                     alt="@photo.Description"
                                     style="cursor: pointer; height: 60px; object-fit: cover;" />
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <img src="@(string.IsNullOrEmpty(Model.Product.Photo)
                                             ? Url.Content("~/images/products/demo.png")
                                             : Url.Content($"~/images/products/{Model.Product.Photo}"))"
                     class="img-fluid rounded"
                     alt="@Model.Product.ProductName"
                     style="height: 300px; object-fit: cover;" />
            }
        </div>
        <div class="col-md-8">
            <h4 class="mb-3">@Model.Product.ProductName</h4>
            
            @if (!string.IsNullOrEmpty(Model.Product.ProductDescription))
            {
                <p class="text-muted mb-3">@Model.Product.ProductDescription</p>
            }
            
            <p class="h5 text-danger mb-3">Giá: <strong>@Model.Product.Price.ToString("N0") đ</strong></p>
            
            <div class="mb-3">
                <p><strong>Đơn vị tính:</strong> @Model.Product.Unit</p>
                <p>
                    <strong>Trạng thái:</strong>
                    @if (Model.Product.IsSelling)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Ngừng bán</span>
                    }
                </p>
            </div>

            @if (Model.Attributes.Any())
            {
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-list-check"></i> Thông số kỹ thuật</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless">
                            <tbody>
                                @foreach (var attr in Model.Attributes)
                                {
                                    <tr>
                                        <td class="fw-bold" style="width: 40%;">@attr.AttributeName</td>
                                        <td>@attr.AttributeValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.Product.IsSelling)
            {
                <button class="btn btn-primary btn-lg w-100" onclick="addToCart(@Model.Product.ProductID)">
                    <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                </button>
            }
            else
            {
                <button class="btn btn-secondary btn-lg w-100" disabled>
                    <i class="bi bi-x-circle me-2"></i> Sản phẩm ngừng bán
                </button>
            }
        </div>
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
</div> 