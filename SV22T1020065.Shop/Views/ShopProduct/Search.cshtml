@model PagedResult<Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

@if (Model.DataItems.Any())
{
    <div class="row">

        @foreach (var item in Model.DataItems)
        {
            <div class="col-md-3 mb-3">
                <div class="card h-100 shadow-sm">

                    <!-- IMAGE -->
                    <img src="@(string.IsNullOrEmpty(item.Photo)
                                                 ? Url.Content("~/images/products/demo.png")
                                                 : Url.Content($"~/images/products/{item.Photo}"))"
                 class="card-img-top"
                 style="height:200px; object-fit:cover;" />

                    <!-- BODY -->
                    <div class="card-body">

                        <h6 class="card-title text-truncate" style="cursor: pointer;" onclick="showProductDetails(@item.ProductID)">
                            @item.ProductName
                        </h6>

                @if (!string.IsNullOrEmpty(item.ProductDescription))
                        {
                            <small class="text-muted d-block mb-1 text-truncate">
                                @item.ProductDescription
                            </small>
                        }

                        <p class="text-danger fw-bold mb-1">
                            @item.Price.ToString("N0") đ
                        </p>

                        <!-- STATUS -->
                        @if (item.IsSelling)
                        {
                            <span class="badge bg-success">Đang bán</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Ngừng bán</span>
                        }

                    </div>

                    <!-- FOOTER -->
                    <div class="card-footer bg-white border-0 d-flex justify-content-between">

                        <button class="btn btn-sm btn-primary flex-fill me-1"
                                onclick="addToCart(@item.ProductID)">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                        </button>

                        <button class="btn btn-sm btn-outline-info flex-fill ms-1"
                                onclick="showProductDetails(@item.ProductID)">
                            <i class="bi bi-info-circle"></i> Chi tiết
                        </button>

                    </div>

                </div>
            </div>
        }

    </div>
}
else
{
    <div class="text-center text-muted">
        Không tìm thấy mặt hàng nào.
    </div>
}

<!-- ===== PAGINATION ===== -->
@if (Model.PageCount > 1)
{
    <div class="mt-3">
        <ul class="pagination justify-content-center mb-0">

            <!-- PREV -->
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   href="javascript:;"
                   onclick="return paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                    «
                </a>
            </li>

            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item @(p.IsCurrent ? "active" : "")">
                        <a class="page-link"
                           href="javascript:;"
                           onclick="return paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }

            <!-- NEXT -->
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   href="javascript:;"
                   onclick="return paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                    »
                </a>
            </li>

        </ul>
    </div>
}