@{
    ViewData["Title"] = "Trang chủ - SV22T1020065 Shop";
}

<style>
    .hero-banner {
        background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
        border-radius: 1rem;
    }

    .btn-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        transition: all 0.3s ease;
    }
</style>



<div class="container mt-4 px-0">
    <div class="hero-banner p-5 mb-4 shadow-sm border text-center">
        <h1 class="display-5 fw-bold text-primary mb-3">Chào mừng bạn đến với SV22T1020065 Shop!</h1>
        <div class="col-lg-8 mx-auto">
            <p class="lead text-dark mb-4">
                Nơi cung cấp các sản phẩm chất lượng, uy tín và đa dạng. Chúng tôi cam kết mang đến trải nghiệm mua sắm trực tuyến an toàn và thuận tiện cho mọi khách hàng.
            </p>
            <p class="text-muted mb-5">
                Tại đây, bạn có thể dễ dàng tìm kiếm sản phẩm theo nhu cầu, thêm vào giỏ hàng và thanh toán nhanh chóng. Đội ngũ nhân viên của chúng tôi luôn sẵn sàng hỗ trợ bạn mọi lúc, mọi nơi.
            </p>

            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a href="~/ShopProduct/Index" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm btn-hover">
                    <i class="fa fa-compass me-2"></i>Khám phá ngay
                </a>
                <a href="~/ShopProduct/Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill shadow-sm btn-hover">
                    Giỏ hàng
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-5 mb-5">
        <h5 class="fst-italic text-secondary">
            <i class="fa fa-quote-left text-primary opacity-50 me-2"></i>
            SV22T1020065 Shop – Uy tín tạo nên sự khác biệt!
            <i class="fa fa-quote-right text-primary opacity-50 ms-2"></i>
        </h5>
    </div>
</div>