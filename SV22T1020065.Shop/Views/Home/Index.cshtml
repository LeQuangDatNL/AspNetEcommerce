}

<nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 shadow-sm">
    <div class="container">
        <a class="navbar-brand font-weight-bold" href="/">SV22T1020065 SHOP</a>

        <form class="d-flex mx-auto w-50" action="~/Home/Index" method="get">
